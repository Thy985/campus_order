# ==========================================
# Docker Compose 环境变量配置
# ==========================================
# 
# 使用说明：
# 1. 复制此文件为 .env
# 2. 修改所有密码和敏感配置
# 3. 运行 docker-compose up -d
# 
# 安全提示：
# - 不要将 .env 文件提交到版本控制系统
# - 生产环境必须使用强密码
# - 定期更换密码
# ==========================================

# ==========================================
# 应用配置
# ==========================================
SPRING_PROFILES_ACTIVE=prod
APP_PORT=9090

# ==========================================
# 数据库配置
# ==========================================
DB_ROOT_PASSWORD=your_root_password_here_please_change
DB_USER=campus_user
DB_PASSWORD=your_db_password_here_please_change
DB_PORT=3306

# ==========================================
# Redis配置
# ==========================================
REDIS_PASSWORD=your_redis_password_here_please_change
REDIS_PORT=6379

# ==========================================
# 支付宝配置
# ==========================================
ALIPAY_APP_ID=your_alipay_app_id
ALIPAY_PRIVATE_KEY=your_alipay_private_key
ALIPAY_PUBLIC_KEY=your_alipay_public_key
ALIPAY_NOTIFY_URL=https://your-domain.com/api/payment/alipay/notify
ALIPAY_RETURN_URL=https://your-domain.com/payment/result
ALIPAY_SANDBOX=false

# ==========================================
# 微信支付配置
# ==========================================
WECHAT_PAY_APP_ID=your_wechat_app_id
WECHAT_PAY_MCH_ID=your_wechat_mch_id
WECHAT_PAY_API_V3_KEY=your_wechat_api_v3_key
WECHAT_PAY_MERCHANT_SERIAL=your_merchant_serial
WECHAT_PAY_PRIVATE_KEY_PATH=/app/config/wechat_private_key.pem
WECHAT_PAY_NOTIFY_URL=https://your-domain.com/api/payment/wechat/notify

# ==========================================
# 文件上传配置
# ==========================================
FILE_ACCESS_URL=https://your-domain.com/files

# ==========================================
# Nginx配置
# ==========================================
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# ==========================================
# 短信服务配置（可选）
# ==========================================
SMS_ENABLED=false
SMS_PROVIDER=aliyun
SMS_ACCESS_KEY_ID=your_aliyun_access_key_id
SMS_ACCESS_KEY_SECRET=your_aliyun_access_key_secret
SMS_SIGN_NAME=校园点餐
SMS_TEMPLATE_VERIFY=your_sms_template_id
