# 开发环境变量配置
# 请根据实际情况修改以下配置

# API基础地址（使用后端同源地址）
VITE_API_BASE_URL=http://localhost:9090

# 应用标题
VITE_APP_TITLE=校园点餐管理系统

# 是否启用调试模式
VITE_DEBUG=true

# 上传文件大小限制（MB）
VITE_MAX_FILE_SIZE=10

# 支付回调地址（开发环境）
VITE_PAYMENT_RETURN_URL=http://localhost:5173/payment/result

# WebSocket地址
VITE_WS_URL=ws://localhost:9090/ws

# 是否启用性能监控
VITE_ENABLE_PERFORMANCE_MONITOR=true

# 是否开启错误追踪
VITE_ENABLE_ERROR_TRACKING=true
